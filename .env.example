# 复制本文件为 .env，并填写仅本地使用的密钥和环境配置。
# 不要提交 .env 文件。

# AI 网关配置。
APP_AI_API_KEY=sk-xxxxxxxxxxxx
APP_AI_BASE_URL=https://api.xxxxxxxx.com
APP_AI_MODEL=gpt-5.5
APP_AI_API_STYLE=RESPONSES
APP_AI_MAX_TOKENS=4096
APP_AI_TEMPERATURE=0.3
APP_AI_TIMEOUT_SECONDS=60

# 本地依赖服务配置。
MYSQL_HOST=localhost
MYSQL_PORT=3309
MYSQL_DATABASE=devops_ai
MYSQL_USERNAME=change-me
MYSQL_PASSWORD=change-me
REDIS_HOST=localhost
REDIS_PORT=7379

# 安全认证配置。
JWT_SECRET=change-me-change-me-change-me-change-me
JWT_EXPIRES_SECONDS=7200

# 日志配置。
APP_LOG_DIR=logs
